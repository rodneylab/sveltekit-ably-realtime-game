{
	"name": "sqvuably",
	"version": "0.0.1",
	"license": "BSD-3-Clause",
	"author": "Rodney Lab <ask@rodneylab.com> (@rodneyLab)",
	"description": "SvelteKit Ably Squares Realtime Multiplayer Game",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin=prettier-plugin-svelte --check . && eslint .",
		"lint:css": "stylelint \"src/**/*.{css,svelte}\"",
		"format": "prettier --write -astro --plugin=prettier-plugin-svelte --plugin=@trivago/prettier-plugin-sort-imports .",
		"check:formatting": "prettier --check --plugin=prettier-plugin-svelte --plugin=@trivago/prettier-plugin-sort-imports .",
		"knip": "knip"
	},
	"devDependencies": {
		"@capsizecss/core": "^4.1.3",
		"@capsizecss/metrics": "^3.7.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@csstools/css-parser-algorithms": "^4.0.0",
		"@csstools/css-tokenizer": "^4.0.0",
		"@csstools/postcss-global-data": "^4.0.0",
		"@eslint/js": "^10.0.1",
		"@js-temporal/polyfill": "^0.5.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/eslint-config-prettier": "^6.11.3",
		"@types/node": "^24.12.2",
		"@typescript-eslint/eslint-plugin": "^8.58.1",
		"@typescript-eslint/parser": "^8.58.1",
		"@upstash/redis": "^1.37.0",
		"ably": "^2.21.0",
		"autoprefixer": "^10.4.27",
		"commitlint": "^20.5.0",
		"dompurify": "^3.3.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"knip": "^6.4.1",
		"postcss": "^8.5.9",
		"postcss-csso": "^6.0.1",
		"postcss-custom-media": "^12.0.1",
		"postcss-html": "^1.8.1",
		"postcss-preset-env": "^11.2.1",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"stylelint": "^17.7.0",
		"stylelint-config-recommended": "^18.0.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"svelte-preprocess": "^6.0.3",
		"svgo": "^4.0.1",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.8",
		"vite-node": "^6.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/rodneylab/sqvuably"
	},
	"bugs": {
		"url": "https://github.com/rodneylab/sqvuably/issues"
	},
	"type": "module",
	"peerDependencies": {
